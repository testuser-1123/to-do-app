  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "pm.environment.set('access_token', data.access);",
                  "pm.environment.set('refresh_token', data.refresh);",
                  "pm.environment.set('username', data.username);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"your_username\",\"password\":\"your_password\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/login/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login",
                ""
              ]
            }
          },
          "response": []
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set(\"access_token\", \"\");\r",
                  "pm.environment.set(\"refresh_token\", \"\");\r",
                  "console.log(\"Токены удалены из окружения\");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"refresh\":\"{{refresh_token}}\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/logout/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "logout",
                ""
              ]
            }
          },
          "response": []
        }
      ]
    },
